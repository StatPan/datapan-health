{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.datapan.dev/datapan.service-status.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "scope", "services"],
  "properties": {
    "schema_version": {"const": "datapan.service-status.v1"},
    "generated_at": {"type": "string", "format": "date-time"},
    "scope": {"const": "datapan_owned_services"},
    "services": {"type": "array", "minItems": 4, "maxItems": 4, "items": {"$ref": "#/$defs/service"}}
  },
  "allOf": [
    {"properties": {"services": {"contains": {"properties": {"service_id": {"const": "dataset-api"}}}}}},
    {"properties": {"services": {"contains": {"properties": {"service_id": {"const": "registry-distribution"}}}}}},
    {"properties": {"services": {"contains": {"properties": {"service_id": {"const": "datapan-web-atlas"}}}}}},
    {"properties": {"services": {"contains": {"properties": {"service_id": {"const": "datapan-health"}}}}}}
  ],
  "$defs": {
    "service": {
      "type": "object", "additionalProperties": false,
      "required": ["service_id", "owner", "surface_kind", "state", "observed_at", "check_id"],
      "properties": {
        "service_id": {"enum": ["dataset-api", "registry-distribution", "datapan-web-atlas", "datapan-health"]},
        "owner": {"enum": ["datapan-data", "datapan-registry", "datapan", "datapan-health"]},
        "surface_kind": {"enum": ["dataset_api", "registry_distribution", "web_delivery", "health_self"]},
        "public_surface": {"type": "string", "format": "uri"},
        "state": {"enum": ["operational", "degraded", "unknown"]},
        "observed_at": {"type": "string", "format": "date-time"},
        "check_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{2,95}$"},
        "deployment_identity": {"type": "string", "pattern": "^[0-9a-f]{40,64}$"},
        "unknown_reason": {"enum": ["deployment_identity_unavailable", "public_surface_unavailable", "configuration_unavailable"]}
      },
      "allOf": [
        {"if": {"properties": {"service_id": {"const": "dataset-api"}}}, "then": {"properties": {"owner": {"const": "datapan-data"}, "surface_kind": {"const": "dataset_api"}, "check_id": {"const": "dataset-api-immutable-deployment"}}}},
        {"if": {"properties": {"service_id": {"const": "registry-distribution"}}}, "then": {"properties": {"owner": {"const": "datapan-registry"}, "surface_kind": {"const": "registry_distribution"}, "check_id": {"const": "registry-distribution-artifact"}}}},
        {"if": {"properties": {"service_id": {"const": "datapan-web-atlas"}}}, "then": {"properties": {"owner": {"const": "datapan"}, "surface_kind": {"const": "web_delivery"}, "check_id": {"const": "datapan-web-immutable-release"}}}},
        {"if": {"properties": {"service_id": {"const": "datapan-health"}}}, "then": {"properties": {"owner": {"const": "datapan-health"}, "surface_kind": {"const": "health_self"}, "check_id": {"const": "health-self-immutable-deployment"}}}},
        {"if": {"properties": {"state": {"const": "unknown"}}}, "then": {"required": ["unknown_reason"], "not": {"required": ["deployment_identity"]}}},
        {"if": {"properties": {"state": {"enum": ["operational", "degraded"]}}}, "then": {"required": ["public_surface", "deployment_identity"], "not": {"required": ["unknown_reason"]}}}
      ]
    }
  }
}
