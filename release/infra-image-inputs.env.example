# Copy the generated values from dist/images/infra-image-inputs.env after the
# approved app build has been promoted to GHCR and the registry returns these
# exact manifest digests. Tags are forbidden by statpan-infra#475.
DATAPAN_HEALTH_IMAGE=ghcr.io/statpan/datapan-health-runtime@sha256:REPLACE_WITH_GENERATED_RUNTIME_MANIFEST_DIGEST
DATAPAN_HEALTH_ARCHIVE_IMAGE=ghcr.io/statpan/datapan-health-archive@sha256:REPLACE_WITH_GENERATED_ARCHIVE_MANIFEST_DIGEST
DATAPAN_HEALTH_RELEASE_REVISION=REPLACE_WITH_APP_GIT_REVISION
DATAPAN_HEALTH_RELEASE_PLATFORM=linux/arm64

# Rollback is explicit and preserves PostgreSQL. Record the currently deployed
# immutable pair before replacing either image reference.
DATAPAN_HEALTH_IMAGE_PREVIOUS=ghcr.io/statpan/datapan-health-runtime@sha256:REPLACE_WITH_PRIOR_RUNTIME_MANIFEST_DIGEST
DATAPAN_HEALTH_ARCHIVE_IMAGE_PREVIOUS=ghcr.io/statpan/datapan-health-archive@sha256:REPLACE_WITH_PRIOR_ARCHIVE_MANIFEST_DIGEST
